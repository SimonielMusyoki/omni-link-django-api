[Unit]
Description=Gunicorn daemon for Omni Link Django API
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/opt/omnilink-api
EnvironmentFile=/opt/omnilink-api/.env.prod
ExecStart=/opt/omnilink-api/.venv/bin/gunicorn \
  --workers 4 \
  --bind 127.0.0.1:8000 \
  --timeout 120 \
  api.wsgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target


# Database Configuration
DB_NAME=omnilink_db
DB_USER=omnilink_user
DB_PASSWORD=omnilink_password
DB_HOST=localhost
DB_PORT=5432

# Google OAuth Configuration (get from Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id-here
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret-here

# Django Secret Key (Generate a new one for production)
DJANGO_SECRET_KEY=django-insecure-j03atacl2d&fp8fqbaqka-xgta!xqrd%)0ju84nsq+3%_s4d0p

# Debug Mode (set to False in production)
DJANGO_DEBUG=True

# Allowed hosts (comma-separated; e.g. api.example.com,localhost)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CSRF trusted origins (comma-separated)
CSRF_TRUSTED_ORIGINS=

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=True

# Shopify
SHOPIFY_WEBHOOK_SECRET=
